<nav class="navbar">
  <button class="w-10 h-10 rounded-md toggle-btn" id="toggle-navbar">
    --</button
  >

  <ul class="nav-list">
    <li><a href="#home">Home</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<script>
  const toggleBtn = document.getElementById("toggle-navbar");
  const navbar = document.querySelector(".navbar");
  const navList = document.querySelector("ul.nav-list");
  const body = document.body;
  const mainContent = document.getElementById("main-content");
  if (toggleBtn && navbar && navList && body) {
    // Initial state for mobile
    if (
      window.innerWidth < 768 &&
      !navbar.classList.contains("collapsed") &&
      mainContent
    ) {
      mainContent.style.display = "none";
    }
    // Set initial icon
    const menuIcon = document.getElementById("menu-icon");
    if (menuIcon && !navbar.classList.contains("collapsed")) {
      menuIcon.setAttribute("d", "M6 18L18 6M6 6l12 12");
    }
    toggleBtn.addEventListener("click", () => {
      navbar.classList.toggle("collapsed");
      const isCollapsed = navbar.classList.contains("collapsed");
      navList.style.display = isCollapsed ? "none" : "flex";
      const menuIcon = document.getElementById("menu-icon");
      if (menuIcon) {
        menuIcon.setAttribute(
          "d",
          isCollapsed ? "M3.75 9h16.5m-16.5 6.75h16.5" : "M6 18L18 6M6 6l12 12",
        );
      }
      if (window.innerWidth >= 768) {
        body.style.marginLeft = isCollapsed ? "50px" : "200px";
      } else {
        body.style.marginLeft = "0px";
        if (mainContent) {
          mainContent.style.display = isCollapsed ? "block" : "none";
        }
      }
    });
  }
</script>

<style>
  .navbar {
    background-color: --var(--bg-color-navbar);
    width: 100%;
    height: 100vh;
    position: fixed;
    left: 0;
    top: 0;
    display: flex;
    flex-direction: column;
    padding: 1rem;
    transition: width 0.3s ease;
    z-index: 1000;
  }

  .navbar.collapsed {
    width: 70px;
  }

  @media (min-width: 768px) {
    .navbar {
      width: 200px;
    }

    .navbar.collapsed {
      width: 50px;
    }
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .nav-list a {
    color: var(--text-color);
    text-decoration: none;
    font-size: 1.2rem;
    padding: 0.5rem;
    border-radius: 4px;
    transition: background-color 0.3s ease;
  }

  .nav-list a:hover {
    background-color: #555;
  }
</style>
