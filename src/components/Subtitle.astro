---
interface Props {
  text?: string;
}

const { text = "Subtítulo" } = Astro.props;
---

<h2 class="text-3xl text-blue-500">
  <slot>{text}</slot>
</h2>

<style>
  h2 {
    font-weight: 600;
    animation:
      slideInText 0.8s ease-in-out,
      colorShift 4s ease-in-out infinite;
  }

  @keyframes slideInText {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes colorShift {
    0% {
      color: #3b82f6;
    }
    50% {
      color: #60a5fa;
    }
    100% {
      color: #3b82f6;
    }
  }
</style>
